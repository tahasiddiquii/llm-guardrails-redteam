# Everything runs offline by default. These are all optional.

# Detection engine: "regex" (default, offline) or "presidio" (needs the presidio extra)
PII_ENGINE=regex

# Policy tuning
BLOCK_SEVERITY=3
REDACT_PII=true

# Optional Langfuse tracing of every scan
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
